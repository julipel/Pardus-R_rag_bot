# Конфигурация для RAG-ассистента
# Скопируйте этот файл в .env и заполните значения

# API ключ OpenAI (обязательно!)
# Используется как для генерации ответов, так и для создания эмбеддингов
# Получите ключ на https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Токен Telegram бота (опционально, для режима Telegram бота)
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID администраторов Telegram (через запятую) — для /stats, /logs, /reindex
# Узнать свой ID: напишите боту @userinfobot
TELEGRAM_ADMIN_IDS=123456789

# Модель для генерации ответов
MODEL_NAME=gpt-3.5-turbo

# Параметр креативности LLM (0.0 — детерминированный, 1.0 — креативный)
TEMPERATURE=0.7

# Максимальная длина ответа LLM (в токенах)
MAX_TOKENS=500

# Количество фрагментов документов для RAG-поиска
TOP_K=3

# Модель для эмбеддингов
EMBEDDING_MODEL=text-embedding-3-small

# Директория ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Имя коллекции ChromaDB
COLLECTION_NAME=rag_documents

# Папка с документами базы знаний (.md и .txt)
DOCS_FOLDER=docs

# Файл кеша ответов
CACHE_FILE=cache.json

# Файл базы данных логов
LOGS_DB_PATH=logs.db
